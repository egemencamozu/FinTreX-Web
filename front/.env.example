# Environment Variables Template
# Copy this file to .env.development or .env.production and fill in the actual values

# Application
APP_ENV=development
APP_NAME=FinTreX
DEBUG=true

# Backend API
API_BASE_URL=http://localhost:3000/api
API_TIMEOUT=30000

# Authentication
AUTH_API_URL=http://localhost:3000/api/auth
JWT_TOKEN_STORAGE_KEY=fintrex_auth_token

# Stripe Payment (Publishable Key - safe for frontend)
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# Market Data APIs
BIST_API_URL=http://localhost:3001/api/bist
BIST_API_KEY=your_bist_api_key

CRYPTO_API_URL=http://localhost:3001/api/crypto
CRYPTO_API_KEY=your_crypto_api_key

PRECIOUS_METALS_API_URL=http://localhost:3001/api/metals
PRECIOUS_METALS_API_KEY=your_metals_api_key

# External Services
MARKET_DATA_API_URL=http://localhost:3001/api/market-data
MARKET_DATA_UPDATE_INTERVAL=5000

# Logging
LOG_LEVEL=debug
ENABLE_CONSOLE_LOGS=true

# Feature Flags
ENABLE_DEMO_MODE=true
ENABLE_MOCK_DATA=false
