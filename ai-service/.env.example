# LLM Provider — CrewAI varsayılan olarak OpenAI kullanır
OPENAI_API_KEY=sk-your-key-here

# Kullanılacak model (gpt-4o-mini önerilir, daha ucuz ve hızlı)
MODEL_NAME=gpt-4o-mini

# FastAPI servis portu
FASTAPI_PORT=8500

# FinTreX Backend API URL (.NET servisi)
BACKEND_API_URL=http://localhost:5000

# LangGraph AI Assistant Ayarları
LANGGRAPH_MODEL_NAME=gpt-4o-mini
GUARDRAIL_MAX_RETRY=2
BACKEND_API_TIMEOUT=30.0
MAX_CONVERSATION_HISTORY=20
