# FinTreX PAA — Environment Configuration Sample
# Bu dosyayı .env olarak kopyala ve doldur

# ==========================================
# OpenAI API Configuration
# ==========================================
# API key'ini https://platform.openai.com/api-keys adresinden al
OPENAI_API_KEY=sk-proj-your-api-key-here

# Model seçimi (maliyet-etkinlik balansı):
# - gpt-4o-mini (RECOMMENDED): Hızlı, ucuz, yeterli
# - gpt-4-turbo: Daha güçlü, daha pahalı
# - gpt-3.5-turbo: En ucuz, daha zayıf
MODEL_NAME=gpt-4o-mini

# ==========================================
# FastAPI Server Configuration
# ==========================================
# PAA microservice'nin çalışacağı port
FASTAPI_PORT=8500

# ==========================================
# Optional: Logging Configuration
# ==========================================
# Log seviyesi (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# ==========================================
# Optional: Backend Integration
# ==========================================
# .NET backend'in PAA servisini çağıracağı adres
# (Bu, backend appsettings.json'da da tanımlanmalı)
# BACKEND_BASE_URL=https://localhost:9001
